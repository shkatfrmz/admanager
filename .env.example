# ============================================
# ON-PREM ACTIVE DIRECTORY SETTINGS
# ============================================
AD_URL=ldap://192.168.1.1                        # Your Domain Controller IP
AD_BASE_DN=dc=yourdomain,dc=com                  # Your base DN
AD_USERNAME=svc-admanager@yourdomain.com         # Service account UPN
AD_PASSWORD=YourServiceAccountPassword           # Service account password
AD_USERS_OU=OU=Users,DC=yourdomain,DC=com        # Default OU for new users

# ============================================
# AZURE AD / GRAPH API SETTINGS
# ============================================
AZURE_TENANT_ID=your-tenant-id                   # From Azure App Registration
AZURE_CLIENT_ID=your-client-id                   # From Azure App Registration
AZURE_CLIENT_SECRET=your-client-secret           # From Azure App Registration

# ============================================
# APP SETTINGS
# ============================================
PORT=3000
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h
NODE_ENV=development
